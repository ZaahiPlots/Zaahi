// ZAAHI — Prisma schema
// Source of truth for User / Parcel / Deal / Document.
// Money: BigInt fils (1 AED = 100 fils). Geometry: GeoJSON polygon as Json.
// User.id == Supabase auth.users.id (no passwordHash here).
// Area is stored in sqft (Dubai market standard).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ENUMS ─────────────────────────────────────────────

enum UserRole {
  OWNER
  BUYER
  BROKER
  INVESTOR
  DEVELOPER
  ARCHITECT
  ADMIN
}

enum ParcelStatus {
  VACANT
  PENDING_REVIEW
  VERIFIED
  REJECTED
  LISTED
  IN_DEAL
  SOLD
  DISPUTED
  FROZEN
}

// Mirrors states in backend/services/deal_engine.ts
enum DealStatus {
  INITIAL
  DEAL_INITIATED
  DEPOSIT_SUBMITTED
  AGREEMENT_SIGNED
  DOCUMENTS_COLLECTED
  GOVERNMENT_VERIFIED
  NOC_REQUESTED
  TRANSFER_FEE_PAID
  DLD_SUBMITTED
  DEAL_COMPLETED
  DISPUTE_INITIATED
  DEAL_CANCELLED
}

enum DocumentType {
  TITLE_DEED
  PASSPORT
  EMIRATES_ID
  NOC
  SPA // Sale & Purchase Agreement
  OQOOD
  EJARI
  POWER_OF_ATTORNEY
  VALUATION_REPORT
  OTHER
}

// Ambassador program commission statuses.
// PENDING  — commission accrued on deal COMPLETE, awaiting payout.
// PAID     — admin marked as paid out (bank/ZAH token/etc).
// REVERSED — deal later cancelled/disputed, commission clawed back.
enum CommissionStatus {
  PENDING
  PAID
  REVERSED
}

// ── MODELS ────────────────────────────────────────────

model User {
  id        String   @id // matches Supabase auth.users.id
  email     String   @unique
  role      UserRole
  name      String
  phone     String?
  createdAt DateTime @default(now())

  // ── Ambassador program ──
  // referralCode: unique 8-char code (generated on ambassador activation)
  // referredById: L1 upline (the user who invited this one). Immutable after set.
  // referredAt:   when the referral cookie was consumed at signup.
  // ambassadorActive: has this user activated ambassador mode (gets commissions)?
  referralCode     String?   @unique
  referredById     String?
  referredAt       DateTime?
  ambassadorActive Boolean   @default(false)

  parcels       Parcel[]      @relation("ParcelOwner")
  dealsAsSeller Deal[]        @relation("DealSeller")
  dealsAsBuyer  Deal[]        @relation("DealBuyer")
  dealsAsBroker Deal[]        @relation("DealBroker")
  dealMessages  DealMessage[]

  referredBy  User?        @relation("UserReferrals", fields: [referredById], references: [id])
  referrals   User[]       @relation("UserReferrals")
  commissions Commission[]

  @@index([role])
  @@index([referredById])
}

model Parcel {
  id               String       @id @default(cuid())
  plotNumber       String
  ownerId          String
  owner            User         @relation("ParcelOwner", fields: [ownerId], references: [id])
  area             Float // sqft (Dubai market standard)
  emirate          String
  district         String
  latitude         Float?
  longitude        Float?
  geometry         Json? // GeoJSON polygon
  status           ParcelStatus @default(VACANT)
  currentValuation BigInt? // fils
  isTokenized      Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  deals          Deal[]
  documents      Document[]
  affectionPlans AffectionPlan[]

  @@unique([emirate, district, plotNumber])
  @@index([ownerId])
  @@index([emirate])
  @@index([district])
  @@index([status])
}

model Deal {
  id       String     @id @default(cuid())
  parcelId String
  parcel   Parcel     @relation(fields: [parcelId], references: [id])
  sellerId String
  seller   User       @relation("DealSeller", fields: [sellerId], references: [id])
  buyerId  String
  buyer    User       @relation("DealBuyer", fields: [buyerId], references: [id])
  brokerId String?
  broker   User?      @relation("DealBroker", fields: [brokerId], references: [id])
  status   DealStatus @default(INITIAL)

  // priceInFils kept for backward compatibility — mirrors offerPriceInFils on create.
  priceInFils       BigInt
  offerPriceInFils  BigInt?
  agreedPriceInFils BigInt?

  paymentType    String? // CASH | MORTGAGE | INSTALLMENT
  mortgageBank   String?
  mortgageAmount BigInt?
  closingDays    Int     @default(90)
  conditions     String?
  initialMessage String?

  depositPaid  Boolean @default(false)
  mouSigned    Boolean @default(false)
  nocReceived  Boolean @default(false)
  dldApproved  Boolean @default(false)
  dldReference String?

  rating Int? // 1..5, set on completion

  // Platform fee (0.25% of agreedPriceInFils) — computed and frozen at DEAL_COMPLETED.
  // Basis for ambassador commission distribution. Null until deal completes.
  platformFeeFils BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents   Document[]
  messages    DealMessage[]
  auditEvents DealAuditEvent[]
  commissions Commission[]

  @@index([parcelId])
  @@index([sellerId])
  @@index([buyerId])
  @@index([brokerId])
  @@index([status])
}

model DealMessage {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  fileUrl   String?
  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([createdAt])
}

model DealAuditEvent {
  id           String   @id @default(cuid())
  dealId       String
  deal         Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  eventType    String // OFFER_SUBMITTED | OFFER_ACCEPTED | COUNTER_OFFER | DEPOSIT_PAID | MOU_SIGNED | NOC_REQUESTED | NOC_RECEIVED | DLD_SUBMITTED | DLD_APPROVED | COMPLETED | CANCELLED | DISPUTED
  txHash       String? // polygon tx hash, or "pending"
  documentHash String? // SHA-256 of related document, if any
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([dealId])
  @@index([txHash])
  @@index([eventType])
}

model AffectionPlan {
  id        String   @id @default(cuid())
  parcelId  String
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  fetchedAt DateTime @default(now())
  source    String // e.g. "gis.dda.gov.ae/DIS"

  plotNumber      String
  oldNumber       String?
  projectName     String?
  community       String?
  masterDeveloper String?

  plotAreaSqm  Float?
  plotAreaSqft Float?
  maxGfaSqm    Float?
  maxGfaSqft   Float?

  maxHeightCode   String? // raw, e.g. "G+15"
  maxFloors       Int?
  maxHeightMeters Float?
  far             Float?

  setbacks       Json? // [{side, building, podium}, ...]
  landUseMix     Json? // [{category, sub, areaSqm}, ...]
  sitePlanIssue  DateTime?
  sitePlanExpiry DateTime?
  notes          String?

  buildingLimitGeometry Json? // GeoJSON Polygon from MAIN_MAP layer 8
  raw                   Json? // full parsed bundle for debugging

  // Optional Salesforce URL for the "Plot Guidelines" PDF that DDA's
  // plot info page surfaces alongside the existing "Plot Details PDF".
  // Format: https://dcca.my.salesforce-sites.com/services/apexrest/GIS?GetPlotSitePlan=<id>
  // Null when DDA didn't expose the link for this plot. Set by
  // scripts/seed-dda + the backfill script. Public URL — no DDA auth.
  plotGuidelinesUrl String?

  // 3D rendering style for this plot. Null or "SIGNATURE" = default ZAAHI
  // tiering (podium/body/crown based on floors). "FLAT" = single block
  // of full footprint at full height — correct for most commercial office
  // buildings that have no visual podium/tower distinction. Data-driven:
  // any parcel can opt in/out per AffectionPlan row; no hardcoded per-plot
  // logic in the renderer.
  buildingStyle String?

  @@index([parcelId])
  @@index([fetchedAt])
}

model Document {
  id         String       @id @default(cuid())
  dealId     String?
  deal       Deal?        @relation(fields: [dealId], references: [id])
  parcelId   String?
  parcel     Parcel?      @relation(fields: [parcelId], references: [id])
  type       DocumentType
  fileUrl    String
  uploadedAt DateTime     @default(now())

  @@index([dealId])
  @@index([parcelId])
  @@index([type])
}

// Immutable, append-only ledger of ambassador commission accruals.
// Never update or delete rows — use status=REVERSED to claw back.
// Computed in awardCommissions() on deal COMPLETE.
model Commission {
  id           String           @id @default(cuid())
  dealId       String
  deal         Deal             @relation(fields: [dealId], references: [id])
  ambassadorId String
  ambassador   User             @relation(fields: [ambassadorId], references: [id])
  level        Int // 1, 2, or 3
  sourceUserId String // the direct referral whose deal triggered this commission
  amountFils   BigInt // commission amount in fils
  basisFils    BigInt // platform fee amount this commission was calculated from
  rate         Decimal          @db.Decimal(5, 4) // 0.3000 / 0.1500 / 0.0500
  status       CommissionStatus @default(PENDING)
  payoutMethod String? // "bank" | "zah_token" | null
  payoutRef    String? // bank transfer ref, tx hash, etc.
  createdAt    DateTime         @default(now())
  paidAt       DateTime?

  // Defense-in-depth against race conditions: a given
  // (deal, ambassador, level, sourceUser) tuple can only exist once.
  // Prevents duplicate commission accrual even if optimistic concurrency
  // control in the caller fails.
  @@unique([dealId, ambassadorId, level, sourceUserId])
  @@index([ambassadorId, status])
  @@index([dealId])
  @@index([level])
  @@index([status])
}

// Analytics-only: records landing page hits on /r/[code].
// Lightweight — no PII, ip is hashed. Safe to prune after 90 days.
model ReferralClick {
  id                String   @id @default(cuid())
  referralCode      String
  ipHash            String? // SHA256(ip+salt) — for dedup, not re-identification
  userAgent         String?
  convertedToUserId String? // filled when a signup is attributed to this click
  createdAt         DateTime @default(now())

  @@index([referralCode])
  @@index([createdAt])
}
