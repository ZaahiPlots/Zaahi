// ZAAHI — Prisma schema
// Source of truth for User / Parcel / Deal / Document.
// Money: BigInt fils (1 AED = 100 fils). Geometry: GeoJSON polygon as Json.
// User.id == Supabase auth.users.id (no passwordHash here).
// Area is stored in sqft (Dubai market standard).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ENUMS ─────────────────────────────────────────────

enum UserRole {
  OWNER
  BUYER
  BROKER
  INVESTOR
  DEVELOPER
  ARCHITECT
  ADMIN
}

enum ParcelStatus {
  VACANT
  PENDING_REVIEW
  VERIFIED
  REJECTED
  LISTED
  IN_DEAL
  SOLD
  DISPUTED
  FROZEN
}

// Mirrors states in backend/services/deal_engine.ts
enum DealStatus {
  INITIAL
  DEAL_INITIATED
  DEPOSIT_SUBMITTED
  AGREEMENT_SIGNED
  DOCUMENTS_COLLECTED
  GOVERNMENT_VERIFIED
  NOC_REQUESTED
  TRANSFER_FEE_PAID
  DLD_SUBMITTED
  DEAL_COMPLETED
  DISPUTE_INITIATED
  DEAL_CANCELLED
}

enum DocumentType {
  TITLE_DEED
  PASSPORT
  EMIRATES_ID
  NOC
  SPA // Sale & Purchase Agreement
  OQOOD
  EJARI
  POWER_OF_ATTORNEY
  VALUATION_REPORT
  OTHER
}

// Ambassador program commission statuses.
// PENDING  — commission accrued on deal COMPLETE, awaiting payout.
// PAID     — admin marked as paid out (bank/ZAH token/etc).
// REVERSED — deal later cancelled/disputed, commission clawed back.
enum CommissionStatus {
  PENDING
  PAID
  REVERSED
}

// ── MODELS ────────────────────────────────────────────

model User {
  id        String   @id // matches Supabase auth.users.id
  email     String   @unique
  role      UserRole
  name      String
  phone     String?
  createdAt DateTime @default(now())

  // ── Ambassador program ──
  // referralCode: unique 8-char code (generated on ambassador activation)
  // referredById: L1 upline (the user who invited this one). Immutable after set.
  // referredAt:   when the referral cookie was consumed at signup.
  // ambassadorActive: has this user activated ambassador mode (gets commissions)?
  referralCode     String?   @unique
  referredById     String?
  referredAt       DateTime?
  ambassadorActive Boolean   @default(false)

  // ── Profile fields (added 2026-04-16 with dashboards Phase 1) ──
  // All nullable/additive; safe to deploy with existing rows. The
  // /dashboard profile form hydrates from these and persists via
  // PATCH /api/me.
  avatarUrl          String?
  bio                String?
  timezone           String?   // IANA, e.g. "Asia/Dubai"
  language           String?   // "EN" | "AR" | "RU" | "UK" | "SQ" | "FR"
  currency           String?   // "AED" | "USD" | "EUR"
  companyName        String?
  reraLicense        String?   // BROKER only
  brnNumber          String?   // BROKER only
  lastSeenAt         DateTime?
  notificationPrefs  Json?     // { inApp: {...}, email: {...}, push: {...} }
  onboardingCompleted Boolean  @default(false)

  parcels       Parcel[]      @relation("ParcelOwner")
  dealsAsSeller Deal[]        @relation("DealSeller")
  dealsAsBuyer  Deal[]        @relation("DealBuyer")
  dealsAsBroker Deal[]        @relation("DealBroker")
  dealMessages  DealMessage[]

  referredBy  User?        @relation("UserReferrals", fields: [referredById], references: [id])
  referrals   User[]       @relation("UserReferrals")
  commissions Commission[]

  // Phase 1 user-dashboard relations
  savedParcels  SavedParcel[]
  parcelViews   ParcelView[]
  notifications Notification[]
  activityLog   ActivityLog[]
  savedSearches SavedSearch[]

  @@index([role])
  @@index([referredById])
}

model Parcel {
  id               String       @id @default(cuid())
  plotNumber       String
  ownerId          String
  owner            User         @relation("ParcelOwner", fields: [ownerId], references: [id])
  area             Float // sqft (Dubai market standard)
  emirate          String
  district         String
  latitude         Float?
  longitude        Float?
  geometry         Json? // GeoJSON polygon
  status           ParcelStatus @default(VACANT)
  currentValuation BigInt? // fils
  isTokenized      Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  deals          Deal[]
  documents      Document[]
  affectionPlans AffectionPlan[]

  // Phase 1 user-dashboard relations
  savedBy    SavedParcel[]
  views      ParcelView[]

  @@unique([emirate, district, plotNumber])
  @@index([ownerId])
  @@index([emirate])
  @@index([district])
  @@index([status])
}

model Deal {
  id       String     @id @default(cuid())
  parcelId String
  parcel   Parcel     @relation(fields: [parcelId], references: [id])
  sellerId String
  seller   User       @relation("DealSeller", fields: [sellerId], references: [id])
  buyerId  String
  buyer    User       @relation("DealBuyer", fields: [buyerId], references: [id])
  brokerId String?
  broker   User?      @relation("DealBroker", fields: [brokerId], references: [id])
  status   DealStatus @default(INITIAL)

  // priceInFils kept for backward compatibility — mirrors offerPriceInFils on create.
  priceInFils       BigInt
  offerPriceInFils  BigInt?
  agreedPriceInFils BigInt?

  paymentType    String? // CASH | MORTGAGE | INSTALLMENT
  mortgageBank   String?
  mortgageAmount BigInt?
  closingDays    Int     @default(90)
  conditions     String?
  initialMessage String?

  depositPaid  Boolean @default(false)
  mouSigned    Boolean @default(false)
  nocReceived  Boolean @default(false)
  dldApproved  Boolean @default(false)
  dldReference String?

  rating Int? // 1..5, set on completion

  // Platform fee (0.25% of agreedPriceInFils) — computed and frozen at DEAL_COMPLETED.
  // Basis for ambassador commission distribution. Null until deal completes.
  platformFeeFils BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents   Document[]
  messages    DealMessage[]
  auditEvents DealAuditEvent[]
  commissions Commission[]

  @@index([parcelId])
  @@index([sellerId])
  @@index([buyerId])
  @@index([brokerId])
  @@index([status])
}

model DealMessage {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  fileUrl   String?
  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([createdAt])
}

model DealAuditEvent {
  id           String   @id @default(cuid())
  dealId       String
  deal         Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  eventType    String // OFFER_SUBMITTED | OFFER_ACCEPTED | COUNTER_OFFER | DEPOSIT_PAID | MOU_SIGNED | NOC_REQUESTED | NOC_RECEIVED | DLD_SUBMITTED | DLD_APPROVED | COMPLETED | CANCELLED | DISPUTED
  txHash       String? // polygon tx hash, or "pending"
  documentHash String? // SHA-256 of related document, if any
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([dealId])
  @@index([txHash])
  @@index([eventType])
}

model AffectionPlan {
  id        String   @id @default(cuid())
  parcelId  String
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  fetchedAt DateTime @default(now())
  source    String // e.g. "gis.dda.gov.ae/DIS"

  plotNumber      String
  oldNumber       String?
  projectName     String?
  community       String?
  masterDeveloper String?

  plotAreaSqm  Float?
  plotAreaSqft Float?
  maxGfaSqm    Float?
  maxGfaSqft   Float?

  maxHeightCode   String? // raw, e.g. "G+15"
  maxFloors       Int?
  maxHeightMeters Float?
  far             Float?

  setbacks       Json? // [{side, building, podium}, ...]
  landUseMix     Json? // [{category, sub, areaSqm}, ...]
  sitePlanIssue  DateTime?
  sitePlanExpiry DateTime?
  notes          String?

  buildingLimitGeometry Json? // GeoJSON Polygon from MAIN_MAP layer 8
  raw                   Json? // full parsed bundle for debugging

  // Optional Salesforce URL for the "Plot Guidelines" PDF that DDA's
  // plot info page surfaces alongside the existing "Plot Details PDF".
  // Format: https://dcca.my.salesforce-sites.com/services/apexrest/GIS?GetPlotSitePlan=<id>
  // Null when DDA didn't expose the link for this plot. Set by
  // scripts/seed-dda + the backfill script. Public URL — no DDA auth.
  plotGuidelinesUrl String?

  // 3D rendering style for this plot. Null or "SIGNATURE" = default ZAAHI
  // tiering (podium/body/crown based on floors). "FLAT" = single block
  // of full footprint at full height — correct for most commercial office
  // buildings that have no visual podium/tower distinction. Data-driven:
  // any parcel can opt in/out per AffectionPlan row; no hardcoded per-plot
  // logic in the renderer.
  buildingStyle String?

  @@index([parcelId])
  @@index([fetchedAt])
}

model Document {
  id         String       @id @default(cuid())
  dealId     String?
  deal       Deal?        @relation(fields: [dealId], references: [id])
  parcelId   String?
  parcel     Parcel?      @relation(fields: [parcelId], references: [id])
  type       DocumentType
  fileUrl    String
  uploadedAt DateTime     @default(now())

  @@index([dealId])
  @@index([parcelId])
  @@index([type])
}

// Immutable, append-only ledger of ambassador commission accruals.
// Never update or delete rows — use status=REVERSED to claw back.
// Computed in awardCommissions() on deal COMPLETE.
model Commission {
  id           String           @id @default(cuid())
  dealId       String
  deal         Deal             @relation(fields: [dealId], references: [id])
  ambassadorId String
  ambassador   User             @relation(fields: [ambassadorId], references: [id])
  level        Int // 1, 2, or 3
  sourceUserId String // the direct referral whose deal triggered this commission
  amountFils   BigInt // commission amount in fils
  basisFils    BigInt // platform fee amount this commission was calculated from
  rate         Decimal          @db.Decimal(5, 4) // 0.3000 / 0.1500 / 0.0500
  status       CommissionStatus @default(PENDING)
  payoutMethod String? // "bank" | "zah_token" | null
  payoutRef    String? // bank transfer ref, tx hash, etc.
  createdAt    DateTime         @default(now())
  paidAt       DateTime?

  // Defense-in-depth against race conditions: a given
  // (deal, ambassador, level, sourceUser) tuple can only exist once.
  // Prevents duplicate commission accrual even if optimistic concurrency
  // control in the caller fails.
  @@unique([dealId, ambassadorId, level, sourceUserId])
  @@index([ambassadorId, status])
  @@index([dealId])
  @@index([level])
  @@index([status])
}

// Ambassador registration applications from the public /join page.
// Paid-tier model (SILVER / GOLD / PLATINUM) — one-time USDT TRC-20 purchase
// for lifetime membership. Commissions live on the Commission table once the
// application is verified and the ambassador user is activated. Rows are
// PENDING until admin verifies the USDT tx, then VERIFIED (ambassador enabled)
// or REJECTED (payment not found / fraud).
model AmbassadorApplication {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  phone           String
  company         String?
  experience      String?
  plan            String // SILVER | GOLD | PLATINUM
  txHash          String
  status          String    @default("PENDING") // PENDING | VERIFIED | ACTIVE | REJECTED
  checklistData   Json? // 10 onboarding checkboxes — all must be true at submit
  // ── Admin review (added 2026-04-15 with admin panel) ──
  // All fields are nullable — populated only when admin acts on the application.
  referralCode    String?   @unique // assigned on approval, merged to User.referralCode at sync
  rejectionReason String?
  approvedAt      DateTime?
  approvedBy      String? // admin user id (supabase sub) or email
  rejectedAt      DateTime?
  rejectedBy      String?
  linkedUserId    String? // populated when the approved applicant eventually signs up
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}

// Analytics-only: records landing page hits on /r/[code].
// Lightweight — no PII, ip is hashed. Safe to prune after 90 days.
model ReferralClick {
  id                String   @id @default(cuid())
  referralCode      String
  ipHash            String? // SHA256(ip+salt) — for dedup, not re-identification
  userAgent         String?
  convertedToUserId String? // filled when a signup is attributed to this click
  createdAt         DateTime @default(now())

  @@index([referralCode])
  @@index([createdAt])
}

// ── Phase 1 user-dashboard models ───────────────────────────────────
// All added 2026-04-16 with USER_DASHBOARDS_RESEARCH.md Phase 1. Additive,
// never modified after create (immutable audit trail for ParcelView /
// ActivityLog / Notification; SavedParcel and SavedSearch rows get
// CRUD'd normally).

// BUYER / OWNER / anyone can save a parcel from the map or detail page.
// @@unique([userId, parcelId]) — saving twice is a no-op upsert.
model SavedParcel {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcelId  String
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, parcelId])
  @@index([userId])
  @@index([parcelId])
}

// Append-only view log. Drives OWNER "who viewed my plot" analytics
// (aggregate only — no PII exposed to owner). Debounced on the client
// so refreshing a page doesn't inflate counts.
//   userId nullable — anonymous viewers logged with ipHash only.
//   Retention: prune rows > 180 days in a scheduled job (Phase 6+).
model ParcelView {
  id        String   @id @default(cuid())
  parcelId  String
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipHash    String?  // SHA256(ip+salt)
  userAgent String?
  viewedAt  DateTime @default(now())

  @@index([parcelId, viewedAt])
  @@index([userId, viewedAt])
}

// In-app notification inbox. `kind` is a machine-readable event type
// (e.g. "PLOT_VIEW_SPIKE", "NEW_OFFER", "SAVED_SEARCH_MATCH"); payload
// is JSON with contextual IDs the UI uses to render links. Email/push
// delivery is a separate pipeline (Phase 6) — this table is the
// source-of-truth inbox.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String    // uppercase snake_case
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// Lightweight user event stream — drives "Recent Activity" in dashboard.
// `kind` parallels Notification.kind. `ref` is an optional link target
// (e.g. parcelId or dealId). Payload is JSON for renderer context.
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  ref       String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// BUYER saved filter + optional bounding box. Triggers alerts when a
// new plot matches (Phase 6 — alert delivery). Max 10 per user enforced
// in API layer, not DB.
//   filters: arbitrary JSON, validated by Zod server-side
//   lastNotifiedAt: last time we emailed/pushed a match
model SavedSearch {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  filters         Json
  locationBounds  Json?     // { minLng, minLat, maxLng, maxLat }
  lastNotifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}
